---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");

const firstPagePosts = posts.slice(0, 6);
const hasMorePosts = posts.length > 6;
---

<Layout title="Blog" description="Latest articles">
  <Hero
    heading="Blog"
    description="This is our contribution to the world. These are what we do."
    buttonText="Me Need Help, Please"
  />

  <section class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        firstPagePosts.map((post) => {
          const image =
            post.data.featuredImage ?? "/featured-images/fallback.jpg";

          return (
            <a
              href={`/blog/${post.id}`}
              class="group block overflow-hidden rounded-2xl border border-zinc-200/60 bg-white transition-all duration-300 hover:-translate-y-1 hover:shadow-xl dark:border-zinc-800 dark:bg-zinc-950"
            >
              <div class="h-48 w-full overflow-hidden">
                <img
                  src={image}
                  alt={post.data.title}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
              </div>

              <div class="p-5">
                <h2 class="text-lg font-semibold leading-snug text-zinc-900 dark:text-white">
                  {post.data.title}
                </h2>

                <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400 line-clamp-3">
                  {post.data.description}
                </p>
              </div>
            </a>
          );
        })
      }
    </div>

    {
      hasMorePosts && (
        <div class="mt-12 flex justify-center">
          <a
            href="/blog/2"
            class="rounded-lg border px-4 py-2 transition hover:bg-zinc-100 dark:hover:bg-zinc-900"
          >
            Next
          </a>
        </div>
      )
    }
  </section>
</Layout>
