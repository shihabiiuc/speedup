---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";

import { getCollection } from "astro:content";
const posts = await getCollection("blog");

import { Image } from "astro:assets";
---

<Layout title="Blog" description="Latest articles">
  <Hero
    heading="Blog"
    description="This is our contribution to the world. These are what we do."
    buttonText="Me Need Help, Please"
  />
  <section class="max-w-5xl mx-auto px-6 py-16">
    <div class="grid gap-6">
      {
        posts.map((post) => {
          console.log(post.data.featuredImage); // <-- debug here

          const image =
            post.data.featuredImage ?? "/featured-images/fallback.jpg";

          return (
            <>
              <a href={`/blog/${post.id}`} class="p-6 border rounded-lg">
                <img
                  src={image}
                  alt={post.data.title}
                  class="w-full h-48 object-cover rounded-lg"
                />

                <h2>{post.data.title}</h2>
                <p>{post.data.description}</p>
              </a>
            </>
          );
        })
      }
    </div>
  </section>
</Layout>
