---
import HeroBlogpost from "../../components/HeroBlogpost.astro";
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

import { Image } from "astro:assets";

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const featuredImage = post.data.featuredImage;
---

<Layout title={post.data.title} description={post.data.description}>
  <HeroBlogpost heading={post.data.title} description={post.data.description} />
  <article
    class="mx-auto max-w-3xl px-6 py-16 prose prose-zinc dark:prose-invert prose-lg
         prose-headings:font-semibold prose-headings:tracking-tight
         prose-p:leading-relaxed"
  >
    {
      featuredImage && (
        <div class="mb-12 overflow-hidden rounded-2xl border border-black/10 dark:border-white/10 shadow-lg">
          <img
            src={featuredImage}
            alt={post.data.title}
            class="!p-0 !m-0 w-full h-auto object-cover"
          />
        </div>
      )
    }

    <Content />
  </article>
</Layout>

<style is:global>
  article.prose h2,
  article.prose h3,
  article.prose h4,
  article.prose h5,
  article.prose h6 {
    margin-top: 60px;
    margin-bottom: 10px;
    line-height: 1.3;
    font-size: 1.5rem;
    font-weight: bold;
  }
  article.prose p {
    margin-bottom: 20px;
  }
  article.prose img {
    border-radius: 12px;
    margin-top: 15px;
    margin-bottom: 30px;
  }
  article.prose {
    line-height: 1.8;
    font-size: 1.125rem;
  }
  article.prose a {
    text-decoration: none;
    border-bottom: 1px solid rgba(6, 97, 111, 0.4);
    color: blue;
  }
  article.prose a:hover {
    border-bottom-color: rgba(34, 211, 238, 1);
    color: rgb(82, 82, 234);
    transition: color 0.3s ease-in;
  }
  article.prose blockquote {
    border-left: 3px solid rgba(34, 211, 238, 0.5);
    padding-left: 1rem;
    color: rgba(161, 161, 170, 1);
    font-style: italic;
  }
  article.prose pre {
    border-radius: 12px;
    padding: 1rem;
    background: rgba(24, 24, 27, 1);
    overflow-x: auto;
  }
</style>
