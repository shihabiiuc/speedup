---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/HeroBlogpost.astro";
---

<Layout>
  <Hero
    heading="404: Not found"
    description="The page you are looking for does not exist."
  />

  <section class="border-t border-gray-200 py-24">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-gray-500">
        Lost somewhere?
      </p>

      <h2 class="mt-4 text-3xl font-bold tracking-tight sm:text-4xl">
        The page may have been moved, deleted, or never existed.
      </h2>

      <p class="mt-6 text-lg leading-8 text-gray-600">
        Try going back to the homepage or explore other sections of the website.
      </p>

      <div
        class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row"
      >
        <a
          href="/"
          class="rounded-full bg-black px-6 py-3 text-sm font-medium text-white transition hover:opacity-90"
        >
          Back to Home
        </a>

        <a
          href="/blog"
          class="rounded-full border border-gray-300 px-6 py-3 text-sm font-medium transition hover:border-black hover:text-black"
        >
          Read the Blog
        </a>
      </div>
    </div>
  </section>
</Layout>
