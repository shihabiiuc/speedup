---
import firstImage from "../assets/images/tecnic-bioprocess-solutions-R4a4zrZ8KfQ-unsplash.jpg";
import secondImage from "../assets/images/tecnic-bioprocess-solutions-xdar9L2_clo-unsplash.jpg";
---

<section class="fun-facts-section">
  <!-- Decorative background elements -->
  <div class="bg-grid-overlay" aria-hidden="true"></div>
  <div class="floating-orb orb-1" aria-hidden="true"></div>
  <div class="floating-orb orb-2" aria-hidden="true"></div>

  <div class="section-header">
    <span class="eyebrow-label">The Performance Edge</span>
    <h2 class="section-title">Built Different.<br /><em>Built Fast.</em></h2>
  </div>

  <!-- ROW 1 -->
  <div class="facts-grid">
    <!-- Col 1: Text -->
    <article class="fact-card card-text card-accent-left" data-index="1">
      <div class="card-inner">
        <div class="card-number">01</div>
        <h3 class="card-heading">Why Website Speed Matters</h3>
        <p class="card-body">
          People expect websites to load instantly. Even a small delay can
          increase bounce rates and reduce conversions. Fast websites help
          businesses:
        </p>
        <ul class="card-list">
          <li>Improve user experience</li>
          <li>Increase conversions and leads</li>
          <li>Rank better in search engines</li>
          <li>Reduce bounce rates</li>
          <li>Perform better on mobile devices</li>
          <li>Achieve better Core Web Vitals scores</li>
        </ul>
        <p class="card-footer-text">
          We focus on creating websites that feel smooth, responsive, and
          reliable.
        </p>
      </div>
    </article>

    <!-- Col 2: Image -->
    <div class="fact-card card-image" data-index="2">
      <div class="image-wrapper">
        <img
          src={firstImage.src}
          alt="Developer working at a computer — focused and productive"
          loading="lazy"
          decoding="async"
        />
        <div class="image-overlay"></div>
        <div class="image-badge">Speed = Revenue</div>
      </div>
    </div>

    <!-- Col 3: Text -->
    <article class="fact-card card-text card-dark" data-index="3">
      <div class="card-inner">
        <div class="card-number">02</div>
        <h3 class="card-heading">What We Do</h3>
        <p class="card-body">
          We specialize in performance-focused web optimization services
          including:
        </p>
        <ul class="card-list">
          <li>Website speed optimization</li>
          <li>Core Web Vitals improvements</li>
          <li>Frontend performance tuning</li>
          <li>Image and asset optimization</li>
          <li>Code cleanup and optimization</li>
          <li>Lazy loading and caching setup</li>
          <li>Modern framework migration</li>
          <li>Mobile performance optimization</li>
        </ul>
        <p class="card-footer-text">
          We work with modern technologies and best practices to ensure your
          website performs at its best.
        </p>
      </div>
    </article>

    <!-- Col 4: Text -->
    <article class="fact-card card-text card-accent-right" data-index="4">
      <div class="card-inner">
        <div class="card-number">03</div>
        <h3 class="card-heading">Our Approach</h3>
        <p class="card-body">
          Every website is different. That's why we start by analyzing your
          website's performance, identifying bottlenecks, and creating a clear
          optimization strategy. Our process typically includes:
        </p>
        <ol class="card-list card-list--ordered">
          <li>Performance audit and analysis</li>
          <li>Identifying speed bottlenecks</li>
          <li>Optimizing assets and code</li>
          <li>Improving loading behavior</li>
          <li>Testing across devices and networks</li>
          <li>Monitoring performance improvements</li>
        </ol>
        <p class="card-footer-text">
          We focus on measurable improvements that make a real difference for
          both users and businesses.
        </p>
      </div>
    </article>

    <!-- Col 5: Image -->
    <div class="fact-card card-image card-image--alt" data-index="5">
      <div class="image-wrapper">
        <img
          src={secondImage.src}
          alt="Modern workspace with clean, minimal aesthetic"
          loading="lazy"
          decoding="async"
        />
        <div class="image-overlay"></div>
        <div class="image-badge image-badge--alt">0.1s = +7% Conversions</div>
      </div>
    </div>

    <!-- Col 6: Text -->
    <article class="fact-card card-text card-highlight" data-index="6">
      <div class="card-inner">
        <div class="card-number">04</div>
        <h3 class="card-heading">Built for Performance</h3>
        <p class="card-body">
          We believe performance should be part of the foundation of every
          website — not an afterthought.
        </p>
        <p class="card-body">
          By combining modern development practices with performance-first
          optimization techniques, we help businesses create websites that are
          faster, cleaner, and more efficient.
        </p>
        <div class="card-cta">
          <span class="cta-line"></span>
          <span class="cta-text">Performance is not optional.</span>
        </div>
      </div>
    </article>
  </div><!-- /facts-grid -->

  <!-- Stats bar -->
  <div class="stats-bar" role="list" aria-label="Key performance statistics">
    <div class="stat-item" role="listitem">
      <span class="stat-value">53%</span>
      <span class="stat-label"
        >of users abandon sites that take over 3s to load</span
      >
    </div>
    <div class="stat-divider" aria-hidden="true"></div>
    <div class="stat-item" role="listitem">
      <span class="stat-value">0.1s</span>
      <span class="stat-label"
        >faster load time = up to 10% increase in conversions</span
      >
    </div>
    <div class="stat-divider" aria-hidden="true"></div>
    <div class="stat-item" role="listitem">
      <span class="stat-value">100</span>
      <span class="stat-label">Lighthouse score is the goal — always</span>
    </div>
  </div>
</section>

<style>
  /* ============================================================
     DESIGN SYSTEM TOKENS
  ============================================================ */
  :root {
    --ff-display: "Syne", "Clash Display", sans-serif;
    --ff-body: "Figtree", "DM Sans", sans-serif;

    --clr-bg: #0a0a0f;
    --clr-surface: #111118;
    --clr-surface-2: #1a1a24;
    --clr-border: rgba(255, 255, 255, 0.07);
    --clr-accent: #e8ff47;
    --clr-accent-2: #7b61ff;
    --clr-accent-3: #ff6b35;
    --clr-text-primary: #f0f0f8;
    --clr-text-muted: #8888a8;
    --clr-text-dimmed: #555570;

    --radius-card: 20px;
    --radius-sm: 10px;
    --gap: clamp(12px, 1.5vw, 20px);
    --pad-card: clamp(28px, 3.5vw, 48px);
  }

  /* ============================================================
     GOOGLE FONTS IMPORT
  ============================================================ */
  @import url("https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=Figtree:wght@300;400;500;600&display=swap");

  /* ============================================================
     SECTION SHELL
  ============================================================ */
  .fun-facts-section {
    position: relative;
    background: var(--clr-bg);
    padding: clamp(80px, 10vw, 140px) clamp(20px, 5vw, 80px);
    overflow: hidden;
    font-family: var(--ff-body);
    color: var(--clr-text-primary);
  }

  /* Grid dot overlay */
  .bg-grid-overlay {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(
      circle,
      rgba(255, 255, 255, 0.04) 1px,
      transparent 1px
    );
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  /* Ambient orbs */
  .floating-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    pointer-events: none;
    z-index: 0;
    animation: drift 12s ease-in-out infinite alternate;
  }
  .orb-1 {
    width: 500px;
    height: 500px;
    background: radial-gradient(
      circle,
      rgba(123, 97, 255, 0.18) 0%,
      transparent 70%
    );
    top: -150px;
    left: -100px;
    animation-delay: 0s;
  }
  .orb-2 {
    width: 400px;
    height: 400px;
    background: radial-gradient(
      circle,
      rgba(232, 255, 71, 0.1) 0%,
      transparent 70%
    );
    bottom: -100px;
    right: -80px;
    animation-delay: -6s;
  }
  @keyframes drift {
    from {
      transform: translate(0, 0) scale(1);
    }
    to {
      transform: translate(40px, 30px) scale(1.08);
    }
  }

  /* ============================================================
     SECTION HEADER
  ============================================================ */
  .section-header {
    position: relative;
    z-index: 1;
    text-align: center;
    margin-bottom: clamp(48px, 6vw, 88px);
  }

  .eyebrow-label {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--ff-body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--clr-accent);
    margin-bottom: 20px;
  }
  .eyebrow-label::before,
  .eyebrow-label::after {
    content: "";
    display: block;
    width: 32px;
    height: 1px;
    background: var(--clr-accent);
    opacity: 0.6;
  }

  .section-title {
    font-family: var(--ff-display);
    font-size: clamp(2.4rem, 5vw, 4.5rem);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--clr-text-primary);
    margin: 0;
  }
  .section-title em {
    font-style: normal;
    color: var(--clr-accent);
    position: relative;
    display: inline-block;
  }
  .section-title em::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -4px;
    width: 100%;
    height: 3px;
    background: var(--clr-accent);
    border-radius: 2px;
  }

  /* ============================================================
     GRID
  ============================================================ */
  .facts-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--gap);
    max-width: 1400px;
    margin: 0 auto;
  }

  @media (min-width: 1024px) {
    .facts-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ============================================================
     BASE CARD
  ============================================================ */
  .fact-card {
    border-radius: var(--radius-card);
    overflow: hidden;
    position: relative;
    transition:
      transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .fact-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 32px 80px rgba(0, 0, 0, 0.5);
  }

  /* ============================================================
     TEXT CARDS
  ============================================================ */
  .card-text {
    background: var(--clr-surface);
    border: 1px solid var(--clr-border);
  }

  .card-inner {
    padding: var(--pad-card);
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* Card variants */
  .card-accent-left {
    border-top: 3px solid var(--clr-accent);
  }
  .card-dark {
    background: var(--clr-surface-2);
    border-top: 3px solid var(--clr-accent-2);
  }
  .card-accent-right {
    border-top: 3px solid var(--clr-accent-3);
  }
  .card-highlight {
    background: linear-gradient(145deg, #161622 0%, #1e1e2e 100%);
    border: 1px solid rgba(123, 97, 255, 0.25);
    border-top: 3px solid var(--clr-accent-2);
  }

  /* Card number */
  .card-number {
    font-family: var(--ff-display);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.2em;
    color: var(--clr-text-dimmed);
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .card-accent-left .card-number {
    color: rgba(232, 255, 71, 0.4);
  }
  .card-dark .card-number {
    color: rgba(123, 97, 255, 0.5);
  }
  .card-accent-right .card-number {
    color: rgba(255, 107, 53, 0.5);
  }
  .card-highlight .card-number {
    color: rgba(123, 97, 255, 0.5);
  }

  /* Headings */
  .card-heading {
    font-family: var(--ff-display);
    font-size: clamp(1.2rem, 2vw, 1.55rem);
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.2;
    color: var(--clr-text-primary);
    margin: 0;
  }

  /* Body text */
  .card-body {
    font-size: clamp(0.875rem, 1.1vw, 0.95rem);
    line-height: 1.7;
    color: var(--clr-text-muted);
    margin: 0;
    font-weight: 300;
  }

  /* Lists */
  .card-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }
  .card-list li {
    font-size: clamp(0.82rem, 1vw, 0.9rem);
    color: var(--clr-text-muted);
    padding-left: 20px;
    position: relative;
    line-height: 1.5;
  }
  .card-list li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--clr-accent);
    font-size: 0.75rem;
    top: 1px;
    font-weight: 700;
  }
  .card-dark .card-list li::before {
    color: var(--clr-accent-2);
  }
  .card-accent-right .card-list li::before {
    color: var(--clr-accent-3);
  }

  /* Ordered list override */
  .card-list--ordered {
    counter-reset: list-counter;
  }
  .card-list--ordered li {
    counter-increment: list-counter;
    padding-left: 28px;
  }
  .card-list--ordered li::before {
    content: counter(list-counter, decimal-leading-zero);
    font-family: var(--ff-display);
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    color: var(--clr-accent-3);
    top: 2px;
  }

  /* Footer text */
  .card-footer-text {
    font-size: 0.82rem;
    color: var(--clr-text-dimmed);
    font-style: italic;
    margin-top: auto;
    padding-top: 12px;
    border-top: 1px solid var(--clr-border);
  }

  /* CTA block inside card-highlight */
  .card-cta {
    margin-top: auto;
    display: flex;
    align-items: center;
    gap: 14px;
    padding-top: 20px;
  }
  .cta-line {
    flex: 1;
    height: 2px;
    background: linear-gradient(90deg, var(--clr-accent-2), transparent);
    border-radius: 2px;
  }
  .cta-text {
    font-family: var(--ff-display);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--clr-accent-2);
    white-space: nowrap;
  }

  /* ============================================================
     IMAGE CARDS
  ============================================================ */
  .card-image {
    min-height: 380px;
    position: relative;
    background: #0d0d12;
  }
  @media (min-width: 1024px) {
    .card-image {
      min-height: 0;
    }
  }

  .image-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 380px;
  }
  .image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .fact-card:hover .image-wrapper img {
    transform: scale(1.04);
  }

  /* Image overlay gradient */
  .image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      160deg,
      rgba(10, 10, 15, 0.55) 0%,
      rgba(10, 10, 15, 0.15) 50%,
      rgba(10, 10, 15, 0.65) 100%
    );
    pointer-events: none;
  }
  .card-image--alt .image-overlay {
    background: linear-gradient(
      160deg,
      rgba(10, 10, 15, 0.6) 0%,
      rgba(123, 97, 255, 0.1) 50%,
      rgba(10, 10, 15, 0.7) 100%
    );
  }

  /* Badge on images */
  .image-badge {
    position: absolute;
    bottom: 24px;
    left: 24px;
    background: var(--clr-accent);
    color: #0a0a0f;
    font-family: var(--ff-display);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 8px 16px;
    border-radius: 6px;
    box-shadow: 0 8px 32px rgba(232, 255, 71, 0.35);
  }
  .image-badge--alt {
    background: var(--clr-accent-2);
    color: #fff;
    box-shadow: 0 8px 32px rgba(123, 97, 255, 0.4);
  }

  /* ============================================================
     STATS BAR
  ============================================================ */
  .stats-bar {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
    margin-top: clamp(48px, 6vw, 80px);
    padding: clamp(32px, 4vw, 52px) clamp(24px, 4vw, 64px);
    max-width: 1400px;
    margin-left: auto;
    margin-right: auto;
    background: var(--clr-surface);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-card);
    border-top: 2px solid var(--clr-accent);
  }
  @media (min-width: 768px) {
    .stats-bar {
      flex-direction: row;
      justify-content: space-around;
      align-items: flex-start;
      gap: 24px;
    }
  }

  .stat-item {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    flex: 1;
  }
  .stat-value {
    font-family: var(--ff-display);
    font-size: clamp(2.5rem, 4vw, 3.8rem);
    font-weight: 800;
    color: var(--clr-accent);
    line-height: 1;
    letter-spacing: -0.03em;
  }
  .stat-label {
    font-size: 0.82rem;
    color: var(--clr-text-muted);
    line-height: 1.5;
    max-width: 200px;
    font-weight: 300;
  }

  .stat-divider {
    display: none;
  }
  @media (min-width: 768px) {
    .stat-divider {
      display: block;
      width: 1px;
      height: 60px;
      background: var(--clr-border);
      flex-shrink: 0;
      align-self: center;
    }
  }

  /* ============================================================
     ANIMATIONS
  ============================================================ */
  @media (prefers-reduced-motion: no-preference) {
    .fact-card {
      opacity: 0;
      transform: translateY(30px);
      animation: fadeUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }
    .fact-card[data-index="1"] {
      animation-delay: 0.05s;
    }
    .fact-card[data-index="2"] {
      animation-delay: 0.15s;
    }
    .fact-card[data-index="3"] {
      animation-delay: 0.25s;
    }
    .fact-card[data-index="4"] {
      animation-delay: 0.35s;
    }
    .fact-card[data-index="5"] {
      animation-delay: 0.45s;
    }
    .fact-card[data-index="6"] {
      animation-delay: 0.55s;
    }

    .stats-bar {
      opacity: 0;
      transform: translateY(20px);
      animation: fadeUp 0.8s 0.65s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    .section-header {
      opacity: 0;
      transform: translateY(20px);
      animation: fadeUp 0.7s 0.05s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }
  }

  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
