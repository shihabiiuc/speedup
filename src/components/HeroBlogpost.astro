---
interface Props {
  heading?: string;
  description?: string;
}

const { heading, description } = Astro.props;
---

<section
  class="relative py-10 flex items-center justify-center overflow-hidden bg-zinc-950"
>
  <!-- Background grid -->
  <div
    class="pointer-events-none absolute inset-0"
    style="background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px); background-size: 64px 64px;"
  >
  </div>

  <!-- Glow blob -->
  <div
    class="pointer-events-none absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] rounded-full opacity-20 blur-3xl"
    style="background: radial-gradient(ellipse, #6366f1 0%, #06b6d4 60%, transparent 100%);"
  >
  </div>

  <!-- Content -->
  <div class="relative z-10 mx-auto max-w-3xl px-6 text-center">
    <!-- Eyebrow tag -->
    <div
      class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-1.5 text-xs font-medium uppercase tracking-widest text-zinc-400"
    >
      <span class="h-1.5 w-1.5 rounded-full bg-cyan-400 animate-pulse"></span>
      Blog Post
    </div>

    <!-- H1 -->
    <h1
      class="font-extrabold leading-none tracking-tight text-white"
      style="font-size: clamp(2.5rem, 8vw, 5rem); font-family: 'Georgia', serif; letter-spacing: -0.03em;"
    >
      {heading}
    </h1>

    <!-- Accent line -->
    <div
      class="mx-auto my-6 h-px w-24 bg-gradient-to-r from-transparent via-cyan-400 to-transparent"
    >
    </div>

    <!-- Description -->
    <p
      class="mx-auto max-w-xl text-base leading-relaxed text-zinc-400 md:text-lg"
    >
      {description}
    </p>
  </div>

  <!-- Bottom fade -->
  <div
    class="pointer-events-none absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-zinc-950 to-transparent"
  >
  </div>
</section>
