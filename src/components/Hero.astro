---
// Hero.astro
// Props you can pass in to customize the component
interface Props {
  heading?: string;
  description?: string;
  buttonText?: string;
  buttonHref?: string;
}

const {
  heading = "Make it Blazing Fast",
  description = "We convert your boring slow loading website into a blazing fast one. No plugin hell, no complex setup. Just pure performance magic.",
  buttonText = "Give Me Some Speed",
  buttonHref = "/contact",
} = Astro.props;
---

<section
  class="relative py-10 flex items-center justify-center overflow-hidden bg-zinc-950"
>
  <!-- Background grid -->
  <div
    class="pointer-events-none absolute inset-0"
    style="background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px); background-size: 64px 64px;"
  >
  </div>

  <!-- Glow blob -->
  <div
    class="pointer-events-none absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] rounded-full opacity-20 blur-3xl"
    style="background: radial-gradient(ellipse, #6366f1 0%, #06b6d4 60%, transparent 100%);"
  >
  </div>

  <!-- Content -->
  <div class="relative z-10 mx-auto max-w-3xl px-6 text-center">
    <!-- Eyebrow tag -->
    <div
      class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-1.5 text-xs font-medium uppercase tracking-widest text-zinc-400"
    >
      <span class="h-1.5 w-1.5 rounded-full bg-cyan-400 animate-pulse"></span>
      Performance Optimization
    </div>

    <!-- H1 -->
    <h1
      class="font-extrabold leading-none tracking-tight text-white"
      style="font-size: clamp(2.5rem, 8vw, 5rem); font-family: 'Georgia', serif; letter-spacing: -0.03em;"
    >
      {heading}
    </h1>

    <!-- Accent line -->
    <div
      class="mx-auto my-6 h-px w-24 bg-gradient-to-r from-transparent via-cyan-400 to-transparent"
    >
    </div>

    <!-- Description -->
    <p
      class="mx-auto max-w-xl text-base leading-relaxed text-zinc-400 md:text-lg"
    >
      {description}
    </p>

    <!-- CTA Button -->
    <div class="mt-10">
      <a
        href={buttonHref}
        class="group relative inline-flex items-center gap-2 overflow-hidden rounded-full bg-white px-8 py-3.5 text-sm font-semibold text-zinc-900 shadow-lg transition-all duration-300 hover:scale-105 hover:shadow-cyan-500/30 hover:shadow-2xl focus:outline-none focus-visible:ring-2 focus-visible:ring-cyan-400 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950"
      >
        <!-- Shimmer sweep on hover -->
        <span
          class="pointer-events-none absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-white/40 to-transparent transition-transform duration-500 group-hover:translate-x-full"
        ></span>
        {buttonText}
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.5"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>
  </div>

  <!-- Bottom fade -->
  <div
    class="pointer-events-none absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-zinc-950 to-transparent"
  >
  </div>
</section>
