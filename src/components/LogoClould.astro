---
const logos = [
  { src: "/logo-cloud/astro.svg", alt: "Astro", label: "Astro" },
  {
    src: "/logo-cloud/cloudflare.png",
    alt: "Cloudflare",
    label: "Cloudflare",
  },
  { src: "/logo-cloud/gulp.png", alt: "Gulp", label: "Gulp" },
  { src: "/logo-cloud/netlify.png", alt: "Netlify", label: "Netlify" },
  { src: "/logo-cloud/next.js.png", alt: "Next.js", label: "Next.js" },
  { src: "/logo-cloud/react.png", alt: "React", label: "React" },
  { src: "/logo-cloud/vercel.svg", alt: "Vercel", label: "Vercel" },
];
---

<section class="py-16">
  <p
    class="text-center text-sm text-zinc-500 font-medium tracking-widest uppercase mb-8"
  >
    We Use Cutting-Edge Tech for You!
  </p>
  <div
    class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-7 gap-3 max-w-4xl mx-auto px-6"
  >
    {
      logos.map((logo) => (
        <div class="group flex flex-col items-center justify-center gap-2.5 rounded-xl border border-white/10 bg-white/5 p-5 transition-all duration-200 hover:border-white/20 hover:bg-white/10">
          <img src={logo.src} alt={logo.alt} class="h-12 w-12 object-contain" />
          <span class="text-xs font-medium text-zinc-500 group-hover:text-zinc-400 transition-colors">
            {logo.label}
          </span>
        </div>
      ))
    }
  </div>
</section>
