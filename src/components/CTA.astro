---
interface Props {
  title?: string;
  description?: string;
  buttonText?: string;
  buttonHref?: string;
  icon?: string;
  accentColor?: string;
}

const {
  title = "Ready to Accelerate?",
  description = "Transform your slow website with lightning-fast performance, superior accessibility, and SEO excellence. Let's build something exceptional together.",
  buttonText = "Get started",
  buttonHref = "/contact",
  icon = "ti-arrow-right",
  accentColor = "#3b82f6",
} = Astro.props;
---

<section class="relative py-32 px-6 overflow-hidden">
  <!-- Background with gradient orb -->
  <div
    class="absolute inset-0 bg-gradient-to-b from-zinc-900 via-zinc-950 to-black"
  >
    <div
      class="absolute top-0 right-0 w-96 h-96 rounded-full blur-3xl opacity-20 -mr-48 -mt-48"
      style={`background: ${accentColor}; filter: blur(120px)`}
    >
    </div>
  </div>

  <!-- Content container -->
  <div class="relative z-10 max-w-2xl mx-auto text-center">
    <!-- Optional decorative icon above heading -->
    {
      icon && (
        <div class="flex justify-center mb-6">
          <div
            class="w-16 h-16 rounded-full flex items-center justify-center opacity-0 animate-fade-in"
            style={`background: ${accentColor}20; border: 1px solid ${accentColor}40`}
          >
            <i
              class={`ti ${icon}`}
              style={`color: ${accentColor}; font-size: 28px`}
              aria-hidden="true"
            />
          </div>
        </div>
      )
    }

    <!-- Heading -->
    <h2
      class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight opacity-0 animate-slide-up"
      style="animation-delay: 0.1s"
    >
      {title}
    </h2>

    <!-- Description -->
    <p
      class="text-lg md:text-xl text-zinc-300 mb-10 leading-relaxed opacity-0 animate-slide-up"
      style="animation-delay: 0.2s"
    >
      {description}
    </p>

    <!-- CTA Button -->
    <div class="opacity-0 animate-slide-up" style="animation-delay: 0.3s">
      <a
        href={buttonHref}
        class="inline-flex items-center justify-center gap-3 px-8 py-4 rounded-2xl font-semibold text-white transition-all duration-300 group relative overflow-hidden"
        style={`background: ${accentColor}; color: white`}
      >
        {/* Hover shine effect */}
        <span
          class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300"
          style={`background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent); pointer-events: none`}
        ></span>

        {/* Button content */}
        <span class="relative flex items-center gap-2">
          {buttonText}
          <i
            class={`ti ${icon}`}
            style="font-size: 18px; transition: transform 0.3s ease; display: inline-block"
            aria-hidden="true"></i>
        </span>

        {/* Expand on hover effect */}
        <style>
          a:hover i {
            transform: translateX(4px);
          }
        </style>
      </a>
    </div>

    <!-- Optional secondary text -->
    <p
      class="text-sm text-zinc-500 mt-8 opacity-0 animate-fade-in"
      style="animation-delay: 0.4s"
    >
      No credit card required • Free consultation
    </p>
  </div>

  <!-- Decorative line elements -->
  <div
    class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-zinc-700 to-transparent opacity-50"
  >
  </div>
</section>

<style>
  @keyframes fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes slide-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fade-in 0.8s ease-out forwards;
  }

  .animate-slide-up {
    animation: slide-up 0.8s ease-out forwards;
  }

  a {
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.1) inset;
  }

  a:hover {
    box-shadow:
      0 0 0 2px rgba(255, 255, 255, 0.2) inset,
      0 8px 32px currentColor;
    filter: brightness(1.1);
  }

  a:active {
    transform: scale(0.98);
  }
</style>
